  "role": {
    "repeater": {
      "icon": "cell_tower",
      "title": "Repeater",
      "tooltip": "MQTT Observer Repeater — forwards mesh packets and uplinks to MQTT brokers"
    },
    "roomServer": {
      "icon": "forum",
      "title": "Room Server",
      "tooltip": "MQTT Observer Room Server — hosts chat rooms and uplinks to MQTT brokers"
    }
  },
  "notice": {
    "partition-change": "<p><b>&#9888; PARTITION TABLE CHANGED:</b> First flash <b>must</b> use &quot;Erase device&quot; (merged firmware). NVS settings will be wiped. After the first flash, standard updates work normally.</p>",
    "tlora-observer": "<p><b>&#9888; NO PSRAM:</b> Only <b>one</b> active WSS/TLS MQTT broker is supported. Configure your preferred broker in slot 1 and set unused slots to <code>none</code>.</p><p><b>&#9888; PARTITION TABLE CHANGED:</b> First flash <b>must</b> use &quot;Erase device&quot; (merged firmware). NVS settings will be wiped. After the first flash, standard updates work normally.</p>"
  },
